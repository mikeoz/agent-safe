# ============================================================================
# Agent Safe — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your Supabase credentials.
#
# Get these values from your Supabase project dashboard:
#   Dashboard → Settings → API Keys
#
# Free tier is sufficient for evaluation and development.
# ============================================================================

# Your Supabase project URL
# Example: https://abcdefghijk.supabase.co
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Your Supabase publishable key (safe to embed in frontend code)
VITE_SUPABASE_ANON_KEY=your-publishable-key-here
SUPABASE_ANON_KEY=your-publishable-key-here

# Your Supabase secret key (KEEP SECRET — never expose in frontend code)
# Used only by the setup script to run migrations.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key-here

# Verification Endpoint API key
# Generate a strong random string: openssl rand -hex 32
# Also store
mkdir -p ~/opnli/agent-safe/scripts
cat > ~/opnli/agent-safe/scripts/setup.sh << 'SETUPEOF'
#!/bin/bash
# ============================================================================
# Agent Safe — Setup Script
# Runs all migrations and seeds the demo data on your Supabase instance.
#
# Usage: ./scripts/setup.sh
#
# Prerequisites:
#   1. Copy .env.example to .env and fill in your Supabase credentials
#   2. Your Supabase project must be running (free tier is fine)
# ============================================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

echo ""
echo "  ╔══════════════════════════════════════╗"
echo "  ║   Agent Safe — Setup Script v1.0     ║"
echo "  ║   CARD Developer Test Kit            ║"
echo "  ╚══════════════════════════════════════╝"
echo ""

ENV_FILE="$ROOT_DIR/.env"
if [ ! -f "$ENV_FILE" ]; then
  echo "  ✗ .env file not found."
  echo "    Run: cp .env.example .env"
  echo "    Then fill in your Supabase credentials."
  exit 1
fi

source "$ENV_FILE"

if [ -z "$SUPABASE_URL" ] || [ "$SUPABASE_URL" = "https://YOUR-PROJECT.supabase.co" ]; then
  echo "  ✗ SUPABASE_URL is not set in .env"
  exit 1
fi

echo "  ✓ Credentials loaded from .env"
echo "  ✓ Supabase URL: $SUPABASE_URL"
echo ""
echo "  The setup script cannot run SQL migrations via the API on"
echo "  Supabase's current architecture. You need to run them manually."
echo ""
echo "  Go to: $SUPABASE_URL → SQL Editor → New query"
echo ""
echo "  Run each file below IN ORDER (paste contents, click Run):"
echo ""

MIGRATION_DIR="$ROOT_DIR/schema/migrations"
echo "    1. $MIGRATION_DIR/001-core-tables.sql"
echo "    2. $MIGRATION_DIR/002-rls-policies.sql"
echo "    3. $MIGRATION_DIR/003-rpcs-core.sql"
echo "    4. $MIGRATION_DIR/004-rpcs-lifecycle.sql"
echo "    5. $MIGRATION_DIR/005-payload-validation.sql"
echo "    6. $MIGRATION_DIR/006-verification-endpoint.sql"
echo ""
echo "  Then run the seed script:"
echo "    7. $ROOT_DIR/demo/seed/bob-bethany-demo-seed.sql"
echo ""
echo "  After running all SQL, run the test script:"
echo "    ./scripts/test-ve.sh"
echo ""
SETUPEOF
chmod +x ~/opnli/agent-safe/scripts/setup.sh
cat > ~/opnli/agent-safe/scripts/test-ve.sh << 'TESTEOF'
#!/bin/bash
# ============================================================================
# Agent Safe — Verification Endpoint Test Suite
# Runs 4 automated tests against the live Verification Endpoint.
#
# Usage: ./scripts/test-ve.sh
# ============================================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

echo ""
echo "  ╔══════════════════════════════════════╗"
echo "  ║   Agent Safe — VE Test Suite v1.0    ║"
echo "  ║   CARD Developer Test Kit            ║"
echo "  ╚══════════════════════════════════════╝"
echo ""

ENV_FILE="$ROOT_DIR/.env"
if [ ! -f "$ENV_FILE" ]; then
  echo "  ✗ .env file not found. Run: cp .env.example .env"
  exit 1
fi

source "$ENV_FILE"

VE_URL="$SUPABASE_URL/functions/v1/verify-card"
KNOWN_AGENT="urn:uuid:5b3a4df1-d71b-4e8c-9c6d-22f12a95c358"
UNKNOWN_AGENT="urn:uuid:00000000-0000-0000-0000-000000000000"

PASS=0
FAIL=0

run_test() {
  local test_num="$1"
  local test_name="$2"
  local expected_status="$3"
  local expected_content="$4"
  local url="$5"
  local api_key="$6"

  printf "  Test %s: %-40s " "$test_num" "$test_name"

  if [ -n "$api_key" ]; then
    RESPONSE=$(curl -s -w "\n%{http_code}" -H "x-api-key: $api_key" "$url" 2>/dev/null)
  else
    RESPONSE=$(curl -s -w "\n%{http_code}" "$url" 2>/dev/null)
  fi

  HTTP_CODE=$(echo "$RESPONSE" | tail -1)
  BODY=$(echo "$RESPONSE" | sed '$d')

  if [ "$HTTP_CODE" = "$expected_status" ]; then
    if [ -n "$expected_content" ]; then
      if echo "$BODY" | grep -q "$expected_content"; then
        echo "✓ PASS (HTTP $HTTP_CODE)"
        PASS=$((PASS + 1))
        return
      else
        echo "✗ FAIL (HTTP $HTTP_CODE, missing: $expected_content)"
        FAIL=$((FAIL + 1))
        return
      fi
    fi
    echo "✓ PASS (HTTP $HTTP_CODE)"
    PASS=$((PASS + 1))
  else
    echo "✗ FAIL (expected $expected_status, got $HTTP_CODE)"
    FAIL=$((FAIL + 1))
  fi
}

# Test 1: Known agent returns active status
run_test "1/4" "AUTHORIZED (known agent)" \
  "200" "active" \
  "$VE_URL?agent_id=$KNOWN_AGENT" \
  "$VERIFY_API_KEY"

# Test 2: Unknown agent returns not_found
run_test "2/4" "DENIED (unknown agent)" \
  "200" "not_found" \
  "$VE_URL?agent_id=$UNKNOWN_AGENT" \
  "$VERIFY_API_KEY"

# Test 3: No API key returns 401
run_test "3/4" "401 UNAUTHORIZED (no API key)" \
  "401" "Unauthorized" \
  "$VE_URL?agent_id=$KNOWN_AGENT" \
  ""

# Test 4: Missing agent_id returns 400
run_test "4/4" "400 BAD REQUEST (missing agent_id)" \
  "400" "Missing required parameter" \
  "$VE_URL" \
  "$VERIFY_API_KEY"

echo ""
echo "  ═══════════════════════════════════════"
echo "  Results: $PASS passed, $FAIL failed (of 4 tests)"
if [ $FAIL -eq 0 ]; then
  echo "  ✓ All tests passed."
else
  echo "  ✗ Some tests failed. Check .env and Edge Function deployment."
fi
echo "  ═══════════════════════════════════════"
echo ""

exit $FAIL
TESTEOF
chmod +x ~/opnli/agent-safe/scripts/test-ve.sh
ls -la ~/opnli/agent-safe/LICENSE ~/opnli/agent-safe/.env.example ~/opnli/agent-safe/scripts/setup.sh ~/opnli/agent-safe/scripts/test-ve.sh
